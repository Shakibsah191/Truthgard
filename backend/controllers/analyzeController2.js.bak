const Analysis = require('../models/Analysis');
const axios = require('axios');
const Groq = require('groq-sdk');

const groq = new Groq({ apiKey: process.env.GROQ_API_KEY });

const analyze = async (req, res) => {
  try {
    const { inputType, inputContent } = req.body;
    const userId = req.user.id;

    console.log('\n========================================');
    console.log('🔍 NEW ANALYSIS REQUEST');
    console.log('========================================');
    console.log(`👤 User ID     : ${userId}`);
    console.log(`📥 Input Type  : ${inputType}`);
    console.log(`📄 Content     : ${inputContent.substring(0, 80)}...`);
    console.log('----------------------------------------');

    // --- Step 1: Call Scraper ---
    let articleText = inputContent;
    let domainAge = null;
    let isHttps = false;

    console.log('\n[Step 1] 🌐 Calling Scraper...');
    try {
      const scraperRes = await axios.post('http://127.0.0.1:8000/scrape', {
        inputType,
        inputContent
      });
      articleText = scraperRes.data.article_text || inputContent;
      domainAge = scraperRes.data.domain_age;
      isHttps = scraperRes.data.is_https;
      console.log(`         ✅ Scraper OK`);
      console.log(`         🔒 HTTPS       : ${isHttps}`);
      console.log(`         📅 Domain Age  : ${domainAge ?? 'unknown'} days`);
      console.log(`         📝 Article Len : ${articleText.length} chars`);
    } catch (err) {
      console.log(`         ❌ Scraper unavailable: ${err.message}`);
      console.log(`         ⚠️  Falling back to raw input`);
    }

    // --- Step 2: Call AI Service ---
    let textScore = 30;
    let aiLabel = 'UNKNOWN';
    let sentiment = 'neutral';
    let clickbaitScore = 0;

    console.log('\n[Step 2] 🤖 Calling ML AI Service...');
    try {
      const aiRes = await axios.post('http://127.0.0.1:8001/analyze-text', {
        text: articleText
      });
      textScore = aiRes.data.text_score;
      aiLabel = aiRes.data.label;
      sentiment = aiRes.data.sentiment;
      clickbaitScore = aiRes.data.clickbait_score;
      console.log(`         ✅ ML Service OK`);
      console.log(`         🏷️  AI Label      : ${aiLabel}`);
      console.log(`         📊 Text Score    : ${textScore}`);
      console.log(`         💬 Sentiment     : ${sentiment}`);
      console.log(`         🎣 Clickbait     : ${clickbaitScore}`);
    } catch (err) {
      console.log(`         ❌ AI service unavailable: ${err.message}`);
      console.log(`         ⚠️  Using default scores`);
    }

    // --- Step 3: Domain Score ---
    let domainScore = 10;
    if (isHttps) domainScore += 20;
    if (domainAge !== null) {
      if (domainAge > 1825) domainScore += 30;
      else if (domainAge > 365) domainScore += 15;
      else domainScore += 5;
    }

    // --- Step 4: Template Score (clickbait based) ---
    const templateScore = Math.max(0, 100 - clickbaitScore);

    // --- Step 5: Headline Score ---
    const headlineScore = sentiment === 'emotional' ? 20 : 60;

    // --- Step 6: ML Final Score ---
    const mlTotalScore =
      (textScore * 0.40) +
      (templateScore * 0.25) +
      (domainScore * 0.20) +
      (headlineScore * 0.15);

    let mlVerdict = 'FAKE';
    if (mlTotalScore >= 70) mlVerdict = 'REAL';
    else if (mlTotalScore >= 40) mlVerdict = 'SUSPICIOUS';

    console.log('\n[Step 3-6] 📐 Score Breakdown...');
    console.log(`         Text Score     : ${textScore}   × 0.40 = ${(textScore * 0.40).toFixed(2)}`);
    console.log(`         Template Score : ${templateScore}  × 0.25 = ${(templateScore * 0.25).toFixed(2)}`);
    console.log(`         Domain Score   : ${domainScore}   × 0.20 = ${(domainScore * 0.20).toFixed(2)}`);
    console.log(`         Headline Score : ${headlineScore}   × 0.15 = ${(headlineScore * 0.15).toFixed(2)}`);
    console.log(`         ─────────────────────────────`);
    console.log(`         ML Total Score : ${Math.round(mlTotalScore)} / 100`);
    console.log(`         ML Verdict     : ${mlVerdict}`);

    // --- Step 7: Groq Cross-Check ---
    let finalVerdict = mlVerdict;

    let finalScore = Math.round(mlTotalScore);

    let groqExplanation = 'Groq unavailable, using ML result.';



    console.log('\n[Step 7] 🧠 Sending to Groq for Cross-Check...');

    try {

      const groqPrompt = `

You are a fake news detection expert. An ML pipeline has already analyzed a piece of content and produced the following scores. Your job is to cross-check using your own knowledge and reasoning, then give a final verdict.



=== ML PIPELINE RESULTS ===

- Text Credibility Score   : ${textScore} / 100  (AI label: ${aiLabel})

- Template/Clickbait Score : ${templateScore} / 100  (Clickbait score: ${clickbaitScore})

- Domain Trust Score       : ${domainScore} / 60   (HTTPS: ${isHttps}, Domain age in days: ${domainAge ?? 'unknown'})

- Headline Sentiment Score : ${headlineScore} / 100  (Sentiment: ${sentiment})

- Weighted Final Score     : ${Math.round(mlTotalScore)} / 100

- ML Verdict               : ${mlVerdict}



=== CONTENT BEING ANALYZED ===

${articleText.substring(0, 1000)}



=== YOUR TASK ===

1. Review the content and the ML scores above.

2. Cross-check whether the ML verdict seems accurate.

3. Respond ONLY in this exact JSON format, no extra text:

{

  "final_score": <number 0-100>,

  "final_verdict": "<REAL | SUSPICIOUS | FAKE>",

  "explanation": "<2-3 sentence reasoning>"

}

`;



      const groqRes = await groq.chat.completions.create({

        model: 'llama-3.1-8b-instant',

        messages: [{ role: 'user', content: groqPrompt }],

        temperature: 0.3

      });



      const raw = groqRes.choices[0]?.message?.content?.trim();

      console.log(`        ✅ Groq responded`);



      // 👇 REPLACE THE PARSING SECTION WITH THIS 👇

      const parsed = JSON.parse(raw);

      finalScore = parsed.final_score ?? finalScore;



      // 🚨 FIRST LOGIC APPLIED HERE: Override Groq's text verdict 🚨

      if (finalScore >= 80) {

        finalVerdict = 'REAL';

      } else if (finalScore >= 45) {

        finalVerdict = 'UNVERIFIED / MIXED';

      } else {

        finalVerdict = 'FAKE';

      }



      groqExplanation = parsed.explanation ?? groqExplanation;



      console.log(`         🎯 Groq Score   : ${finalScore} / 100`);

      console.log(`         🏁 Groq Verdict : ${finalVerdict}`);

      console.log(`         💡 Explanation  : ${groqExplanation}`);



    } catch (err) {

      console.log(`         ❌ Groq error: ${err.message}`);

      console.log(`         ⚠️  Falling back to ML verdict`);

    }

    // --- Step 8: Save Record ---
    console.log('\n[Step 8] 💾 Saving to Database...');
    const record = await Analysis.create({
      userId,
      inputType,
      inputContent,
      totalScore: finalScore,
      verdict: finalVerdict,
      textScore,
      templateScore,
      domainScore,
      headlineScore,
      details: {
        articleText: articleText.substring(0, 500),
        domainAge,
        isHttps,
        aiLabel,
        sentiment,
        clickbaitScore,
        mlTotalScore: Math.round(mlTotalScore),
        mlVerdict,
        groqExplanation,
        note: 'Scraper + AI + Groq Cross-Check ✅'
      }
    });

    console.log(`         ✅ Saved — Record ID : ${record.id}`);
    console.log('\n========================================');
    console.log(`✅ ANALYSIS COMPLETE`);
    console.log(`   Final Score   : ${finalScore} / 100`);
    console.log(`   Final Verdict : ${finalVerdict}`);
    console.log('========================================\n');

    res.status(201).json({ message: 'Analysis complete', result: record });
  } catch (err) {
    console.log('\n❌ SERVER ERROR:', err.message);
    res.status(500).json({ message: 'Server error', error: err.message });
  }
};

const getHistory = async (req, res) => {
  try {
    const records = await Analysis.findAll({
      where: { userId: req.user.id },
      order: [['createdAt', 'DESC']]
    });
    res.json(records);
  } catch (err) {
    res.status(500).json({ message: 'Server error', error: err.message });
  }
};

module.exports = { analyze, getHistory };
