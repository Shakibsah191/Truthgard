const Analysis = require('../models/Analysis');
const axios = require('axios');
const Groq = require('groq-sdk');

const groq = new Groq({ apiKey: process.env.GROQ_API_KEY });

// ============================================================
// 🌍 REALITY ANCHOR — Injected into EVERY LLM call as system prompt
// Update this object whenever political reality changes.
// ============================================================

const today = new Date();
const formattedDate = today.toISOString().split('T')[0];

const REALITY_ANCHOR = `
You are a senior Bangladeshi fact-checker. Today's date is ${formattedDate}.

CONFIRMED CURRENT FACTS (treat these as absolute ground truth):
- Bangladesh PM: Tarique Rahman (took office 2025, BNP-led government)
- Sheikh Hasina: Fled Bangladesh in August 2024, NO longer PM, NO longer in power
- Awami League: Currently NOT in government
- If any article presents Sheikh Hasina as the ACTIVE/CURRENT Prime Minister, that is FACTUALLY WRONG.
- If any article presents an Awami League minister as currently serving in government, that is FACTUALLY WRONG.

Your job is ONLY to follow the exact instruction given. Do not add extra commentary.
Always return valid JSON and nothing else.
`.trim();

// ============================================================
// 📦 CATEGORY DEFINITIONS
// ============================================================
const CATEGORIES = {
    POLITICS: {
        name: 'Politics',
        emoji: '🏛️',
        extractFocus: 'Extract: (1) Full name of the leader/official mentioned, (2) Their claimed title/position, (3) The specific government action or event claimed, (4) Any specific numbers (budget, crore, votes).',
        searchStrategy: 'Search for the PERSON\'s current role first, then the specific event.',
        contradictionFocus: 'Pay special attention to whether the person\'s title/position is correct for 2026.',
    },
    HEALTH: {
        name: 'Health',
        emoji: '🏥',
        extractFocus: 'Extract: (1) Disease or health issue name, (2) Death/affected count, (3) Hospital or health organization name (e.g. DGHS, WHO, IEDCR), (4) Location of outbreak.',
        searchStrategy: 'Search for the health organization confirmation of this event.',
        contradictionFocus: 'Pay special attention to whether the statistics and organization names are real.',
    },
    SPORTS: {
        name: 'Sports',
        emoji: '⚽',
        extractFocus: 'Extract: (1) Sport type, (2) Team or player names, (3) Match result or score, (4) Tournament/competition name, (5) Date of match.',
        searchStrategy: 'Search for the official match result from a sports authority.',
        contradictionFocus: 'Pay special attention to whether the score and teams match official records.',
    },
    ECONOMY: {
        name: 'Economy',
        emoji: '💰',
        extractFocus: 'Extract: (1) Specific Taka/dollar figures mentioned, (2) Ministry or organization making the claim, (3) Economic indicator (inflation, GDP, budget), (4) Time period referenced.',
        searchStrategy: 'Search for the Bangladesh Bank or Ministry of Finance confirmation.',
        contradictionFocus: 'Pay special attention to whether the figures are realistic and match official announcements.',
    },
    WORLD: {
        name: 'World News',
        emoji: '🌍',
        extractFocus: 'Extract: (1) Country or countries involved, (2) Leader or official name and their title, (3) The specific international event or agreement, (4) Date or timeframe.',
        searchStrategy: 'Search for international news agency confirmation of this event.',
        contradictionFocus: 'Pay special attention to whether the leader names and their positions are correct.',
    },
    GENERAL: {
        name: 'General',
        emoji: '📰',
        extractFocus: 'Extract: (1) The single most important claim in the article, (2) Any named person and their role, (3) Any specific numbers or statistics, (4) The location of the event.',
        searchStrategy: 'Search for the main claim directly.',
        contradictionFocus: 'Pay special attention to whether the main claim can be confirmed by any reliable source.',
    },
};

// ============================================================
// 🧮 FIXED MATH SCORING — Node.js calculates, LLM never scores
// ============================================================
const calculateScore = ({ mlScore, webMatchResult, categoryPenalty, domainBonus }) => {
    let score = 50;

    if (webMatchResult === 'YES') score += 40;
    else if (webMatchResult === 'PARTIAL') score += 10;
    else if (webMatchResult === 'NO') score -= 30;
    else score += 0;

    // NLI score contributes max ±15 pts (same slot as old ML)
    const mlContribution = ((mlScore - 50) / 50) * 15;
    score += mlContribution;

    score -= categoryPenalty;
    score += domainBonus;

    return Math.round(Math.max(0, Math.min(100, score)));
};

const scoreToVerdict = (score) => {
    if (score >= 75) return 'REAL';
    if (score >= 55) return 'LIKELY REAL';
    if (score >= 35) return 'SUSPICIOUS';
    return 'FAKE';
};

// ============================================================
// 🔍 STEP 3A — Detect Category
// ============================================================
const detectCategory = async (articleText) => {
    const prompt = `
Classify this Bengali news article into EXACTLY ONE of these categories:
POLITICS, HEALTH, SPORTS, ECONOMY, WORLD, GENERAL

Rules:
- POLITICS: Bangladesh government, ministers, PM, elections, parliament
- HEALTH: disease, hospital, medicine, outbreak, death from illness
- SPORTS: cricket, football, match, tournament, player, score
- ECONOMY: taka, budget, price, inflation, bank, GDP, export, import
- WORLD: international events, foreign countries, global leaders
- GENERAL: anything else

Return JSON only: { "category": "POLITICS" }

Article: ${articleText.substring(0, 600)}`;

    const res = await groq.chat.completions.create({
        model: 'llama-3.1-8b-instant',
        messages: [
            { role: 'system', content: REALITY_ANCHOR },
            { role: 'user', content: prompt }
        ],
        response_format: { type: 'json_object' },
        temperature: 0,
    });

    const parsed = JSON.parse(res.choices[0].message.content);
    const cat = parsed.category?.toUpperCase();
    return CATEGORIES[cat] ? cat : 'GENERAL';
};

// ============================================================
// 🔎 STEP 3B — Extract MAIN CLAIM + Supporting Claims
// ============================================================
const extractClaims = async (articleText, categoryKey) => {
    const cat = CATEGORIES[categoryKey];

    const prompt = `
You are extracting claims from a Bengali news article for fact-checking.

CATEGORY: ${cat.name}
FOCUS: ${cat.extractFocus}

CRITICAL — You must identify:
1. MAIN_CLAIM: The single most central, verifiable fact of this article.
2. SUPPORTING_CLAIMS: 2-4 secondary details (numbers, names, dates).
3. SEARCH_QUERY: A 5-8 word English search query to verify the MAIN CLAIM.
   Use official English acronyms for Bangladeshi organizations (BRTA, BRTC, DGHS, ACC, BBS, NBR, BB).

Return JSON only:
{
  "main_claim": "One sentence describing the core verifiable claim",
  "supporting_claims": ["claim 1", "claim 2", "claim 3"],
  "search_query": "5-8 word english query",
  "key_person": "Full name of main person mentioned or null",
  "key_person_title": "Their claimed title/position or null"
}

Article: ${articleText.substring(0, 1000)}`;

    const res = await groq.chat.completions.create({
        model: 'llama-3.1-8b-instant',
        messages: [
            { role: 'system', content: REALITY_ANCHOR },
            { role: 'user', content: prompt }
        ],
        response_format: { type: 'json_object' },
        temperature: 0,
    });

    const parsed = JSON.parse(res.choices[0].message.content);
    return {
        mainClaim: parsed.main_claim || 'Unknown main claim',
        supportingClaims: Array.isArray(parsed.supporting_claims) ? parsed.supporting_claims : [],
        searchQuery: parsed.search_query || '',
        keyPerson: parsed.key_person || null,
        keyPersonTitle: parsed.key_person_title || null,
    };
};

// ============================================================
// ⚖️ STEP 5A — Compare claims vs web reality
// ============================================================
const compareClaimsVsWeb = async (mainClaim, supportingClaims, webContext, categoryKey) => {
    const cat = CATEGORIES[categoryKey];

    const prompt = `
You are comparing an article's claims against web research results.

MAIN CLAIM (most important — focus here first):
"${mainClaim}"

SUPPORTING CLAIMS:
${supportingClaims.map((c, i) => `${i + 1}. ${c}`).join('\n')}

WEB RESEARCH RESULT:
"${webContext}"

VERIFICATION FOCUS: ${cat.contradictionFocus}

YOUR TASK:
1. Does the web research CONFIRM or CONTRADICT the MAIN CLAIM?
2. Are any supporting claims contradicted by web research?

RULES:
- If the MAIN CLAIM is directly contradicted by web research → answer is "NO"
- If the MAIN CLAIM is confirmed by web research → answer is "YES"  
- If web research is about a different topic or too vague to judge → answer is "UNKNOWN"
- If main claim is partially confirmed but some details are wrong → "PARTIAL"
- The MAIN CLAIM has highest priority.

Return JSON only:
{
  "main_claim_verdict": "YES | NO | PARTIAL | UNKNOWN",
  "main_claim_reason": "One sentence why",
  "contradiction_found": true | false,
  "contradiction_detail": "What specifically is contradicted, or null"
}`;

    const res = await groq.chat.completions.create({
        model: 'llama-3.1-8b-instant',
        messages: [
            { role: 'system', content: REALITY_ANCHOR },
            { role: 'user', content: prompt }
        ],
        response_format: { type: 'json_object' },
        temperature: 0,
    });

    const parsed = JSON.parse(res.choices[0].message.content);
    return {
        webMatchResult: parsed.main_claim_verdict || 'UNKNOWN',
        mainClaimReason: parsed.main_claim_reason || '',
        contradictionFound: parsed.contradiction_found || false,
        contradictionDetail: parsed.contradiction_detail || null,
    };
};

// ============================================================
// 📊 STEP 5B — Category-specific reality penalty
// ============================================================
const getCategoryPenalty = (categoryKey, extracted, webContext) => {
    let penalty = 0;
    const webLower = webContext.toLowerCase();

    if (categoryKey === 'POLITICS') {
        const { keyPerson, keyPersonTitle } = extracted;

        const hashinaAsActivePM = keyPerson?.toLowerCase().includes('hasina') &&
            keyPersonTitle?.toLowerCase().includes('prime minister');

        const awamilLeagueInPower = webLower.includes('awami league') &&
            (webLower.includes('minister') || webLower.includes('government')) &&
            !webLower.includes('opposition');

        if (hashinaAsActivePM) {
            penalty += 35;
            console.log('         🚨 REALITY CHECK FAIL: Article claims Hasina is active PM → penalty -35');
        }

        if (awamilLeagueInPower) {
            penalty += 15;
            console.log('         ⚠️ REALITY CHECK: Awami League claimed in power → penalty -15');
        }
    }

    if (categoryKey === 'HEALTH') {
        const hasOrgConfirmation = webLower.includes('dghs') || webLower.includes('iedcr') ||
            webLower.includes('who') || webLower.includes('health ministry');
        if (!hasOrgConfirmation && extracted.mainClaim.match(/\d{4,}/)) {
            penalty += 10;
            console.log('         ⚠️ HEALTH CHECK: Large numbers, no org confirmation → penalty -10');
        }
    }

    if (categoryKey === 'ECONOMY') {
        const hasSourceConfirmation = webLower.includes('bangladesh bank') ||
            webLower.includes('nbr') || webLower.includes('finance ministry') ||
            webLower.includes('ministry of finance');
        if (!hasSourceConfirmation && extracted.mainClaim.match(/\d+\s*lakh\s*crore|\d+\s*হাজার\s*কোটি/i)) {
            penalty += 15;
            console.log('         ⚠️ ECONOMY CHECK: Massive figures with no official source → penalty -15');
        }
    }

    return penalty;
};

// ============================================================
// ✍️ STEP 5D — LLM writes the explanation ONLY
// ============================================================
const generateExplanation = async (finalScore, finalVerdict, mainClaim, webMatchResult, contradictionDetail, categoryKey) => {
    const cat = CATEGORIES[categoryKey];

    const prompt = `
Write a 2-sentence explanation for a fact-check result. Be direct and clear.

Category: ${cat.name}
Final Score: ${finalScore}/100
Final Verdict: ${finalVerdict}
Main Claim Checked: "${mainClaim}"
Web Verification Result: ${webMatchResult}
Contradiction Found: ${contradictionDetail || 'None'}

Write as if explaining to a regular reader why this article got this verdict.
Do NOT mention the score. Do NOT say "Based on our analysis". Just explain what was found.

Return JSON only: { "explanation": "2 sentences here." }`;

    const res = await groq.chat.completions.create({
        model: 'llama-3.1-8b-instant',
        messages: [
            { role: 'system', content: REALITY_ANCHOR },
            { role: 'user', content: prompt }
        ],
        response_format: { type: 'json_object' },
        temperature: 0.3,
    });

    const parsed = JSON.parse(res.choices[0].message.content);
    return parsed.explanation || 'Verification complete.';
};

// ============================================================
// 🚀 MAIN ANALYZE FUNCTION
// ============================================================
const analyze = async (req, res) => {
    try {
        const { inputType, inputContent } = req.body;
        const userId = req.user.id;

        // 🛑 STEP 0: GATEKEEPER
        if (inputType === 'text') {
            const wordCount = inputContent.trim().split(/\s+/).length;
            if (wordCount > 2500) {
                return res.status(400).json({ message: `Text is too long (${wordCount} words). Max is 2500.` });
            }
            if (wordCount < 20) {
                return res.status(400).json({ message: 'Text is too short to analyze reliably. Please provide a full article.' });
            }
        }

        console.log('\n==================================================');
        console.log('🔍 NEW ANALYSIS REQUEST: TRUTHGUARD V8.0 PIPELINE');
        console.log('==================================================');
        console.log(`👤 User ID    : ${userId}`);
        console.log(`📄 Input      : "${inputContent.substring(0, 60)}..."`);
        console.log('--------------------------------------------------');

        // ─────────────────────────────────────────────────────
        // 🌐 STEP 1: SCRAPE & CLEAN
        // ─────────────────────────────────────────────────────
        console.log('\n[STEP 1] 🌐 Scraping & Preparing Content');
        let articleText = inputContent;
        let domainAge = null;
        let isHttps = false;

        try {
            const scraperRes = await axios.post('http://127.0.0.1:8000/scrape', { inputType, inputContent }, { timeout: 8000 });
            articleText = scraperRes.data.article_text || inputContent;
            domainAge = scraperRes.data.domain_age;
            isHttps = scraperRes.data.is_https;
            console.log(`         ✅ Scraper OK | Length: ${articleText.length} chars | HTTPS: ${isHttps} | Domain Age: ${domainAge || 'unknown'}`);
        } catch (e) {
            console.log(`         ⚠️ Scraper offline → using raw input text`);
        }

        // Domain trust bonus (max 10 pts)
        let domainBonus = 0;
        if (isHttps) domainBonus += 5;
        if (domainAge && domainAge > 365) domainBonus += 5;

        // ─────────────────────────────────────────────────────
        // ⏭️ STEP 2: ML REMOVED — NLI will run after web search
        // mlScore starts neutral. NLI will update it in Step 5C.
        // ─────────────────────────────────────────────────────
        console.log('\n[STEP 2] ⏭️ ML skipped — NLI fact-check runs after web search (Step 5C)');
        let mlScore = 50; // neutral placeholder — will be replaced by NLI score

        // Pipeline state variables
        let finalScore = 50;
        let finalVerdict = 'SUSPICIOUS';
        let groqExplanation = 'Analysis pipeline partially failed. Result based on available signals only.';
        let pipelineSucceeded = false;
        let detectedCategory = 'GENERAL';
        let extracted = {};
        let comparisonResult = {};
        let nliVerdict = 'NEUTRAL'; // for logging

        try {
            // ─────────────────────────────────────────────────────
            // 🏷️ STEP 3A: DETECT CATEGORY
            // ─────────────────────────────────────────────────────
            console.log('\n[STEP 3A] 🏷️ Detecting Article Category');
            detectedCategory = await detectCategory(articleText);
            const cat = CATEGORIES[detectedCategory];
            console.log(`         ✅ Category: ${cat.emoji} ${cat.name}`);

            // ─────────────────────────────────────────────────────
            // 🔎 STEP 3B: EXTRACT MAIN CLAIM + SUPPORTING CLAIMS
            // ─────────────────────────────────────────────────────
            console.log('\n[STEP 3B] 🔎 Extracting Main Claim & Supporting Claims');
            extracted = await extractClaims(articleText, detectedCategory);
            console.log(`         ✅ Main Claim  : "${extracted.mainClaim}"`);
            console.log(`         📋 Supporting  : [${extracted.supportingClaims.join(' | ')}]`);
            console.log(`         🔑 Key Person  : ${extracted.keyPerson || 'None'} (${extracted.keyPersonTitle || 'N/A'})`);
            console.log(`         🔍 Search Query: "${extracted.searchQuery}"`);

            // ─────────────────────────────────────────────────────
            // 🌐 STEP 4: LIVE WEB SEARCH
            // ─────────────────────────────────────────────────────
            console.log('\n[STEP 4] 🌐 Cross-Referencing Live Web');

            const finalQuery = `${extracted.searchQuery} Bangladesh 2026`;
            const tavilyRes = await axios.post('https://api.tavily.com/search', {
                api_key: process.env.TAVILY_API_KEY,
                query: finalQuery,
                search_depth: 'basic',
                include_answer: true,
                max_results: 5,
            }, { timeout: 10000 });

            const webContext = tavilyRes.data.answer || 'No relevant information found online.';
            console.log(`         ✅ Web Search Done | Context: ${webContext.length} chars`);
            console.log(`         📄 Summary: "${webContext.substring(0, 100)}..."`);

            // ─────────────────────────────────────────────────────
            // ⚖️ STEP 5A: COMPARE CLAIMS VS WEB (LLM)
            // ─────────────────────────────────────────────────────
            console.log('\n[STEP 5A] ⚖️ Comparing Main Claim Against Web Reality');
            comparisonResult = await compareClaimsVsWeb(
                extracted.mainClaim,
                extracted.supportingClaims,
                webContext,
                detectedCategory
            );
            console.log(`         ✅ Web Match  : ${comparisonResult.webMatchResult}`);
            console.log(`         📌 Reason     : ${comparisonResult.mainClaimReason}`);
            if (comparisonResult.contradictionFound) {
                console.log(`         🚨 Contradiction: ${comparisonResult.contradictionDetail}`);
            }

            // ─────────────────────────────────────────────────────
            // 🚨 STEP 5B: CATEGORY REALITY PENALTY
            // ─────────────────────────────────────────────────────
            console.log('\n[STEP 5B] 🚨 Applying Category Reality Checks');
            const categoryPenalty = getCategoryPenalty(detectedCategory, extracted, webContext);
            console.log(`         📉 Category Penalty: -${categoryPenalty} pts`);

            // ─────────────────────────────────────────────────────
            // 🔬 STEP 5C: NLI FACT VERIFICATION
            // Premise  = web evidence (what the internet says is true)
            // Hypothesis = main claim (what the article claims)
            // If ENTAILMENT → web supports the claim → high nli score
            // If CONTRADICTION → web opposes the claim → low nli score
            // ─────────────────────────────────────────────────────
            console.log('\n[STEP 5C] 🔬 NLI Fact Verification (Claim vs Web Evidence)');
            try {
                const nliRes = await axios.post('http://127.0.0.1:8001/nli-verify', {
                    web_context: webContext,      // REAL web evidence from Tavily
                    main_claim: extracted.mainClaim
                }, { timeout: 10000 });

                mlScore = nliRes.data.nli_score ?? 50;
                nliVerdict = nliRes.data.verdict ?? 'NEUTRAL';
                console.log(`         ✅ NLI Score  : ${Math.round(mlScore)}/100`);
                console.log(`         🧠 NLI Verdict: ${nliVerdict} (ENTAILMENT=supports claim, CONTRADICTION=opposes claim, NEUTRAL=unclear)`);
                console.log(`         📊 Contribution: max ±15 pts to final score`);
            } catch (nliErr) {
                // NLI is optional — if it fails, keep mlScore = 50 (neutral)
                console.log(`         ⚠️ NLI offline → using neutral 50 (no contribution to score)`);
                console.log(`         ↳ Error: ${nliErr.message}`);
            }

            // ─────────────────────────────────────────────────────
            // 🧮 STEP 5D: FIXED MATH SCORING
            // ─────────────────────────────────────────────────────
            console.log('\n[STEP 5D] 🧮 Calculating Final Score (Fixed Math)');
            finalScore = calculateScore({
                mlScore,      // now = NLI score (or 50 if NLI failed)
                webMatchResult: comparisonResult.webMatchResult,
                categoryPenalty,
                domainBonus,
            });
            finalVerdict = scoreToVerdict(finalScore);

            const nliContrib = Math.round(((mlScore - 50) / 50) * 15);
            console.log(`         📊 Score Breakdown:`);
            console.log(`            Base Score            : 50`);
            console.log(`            Web Match (${comparisonResult.webMatchResult.padEnd(7)}): ${comparisonResult.webMatchResult === 'YES' ? '+40' : comparisonResult.webMatchResult === 'PARTIAL' ? '+10' : comparisonResult.webMatchResult === 'NO' ? '-30' : '  0'}`);
            console.log(`            NLI Contribution      : ${nliContrib >= 0 ? '+' : ''}${nliContrib} (verdict: ${nliVerdict})`);
            console.log(`            Category Penalty      : -${categoryPenalty}`);
            console.log(`            Domain Bonus          : +${domainBonus}`);
            console.log(`            ──────────────────────────`);
            console.log(`            FINAL SCORE           : ${finalScore}/100 → ${finalVerdict}`);

            // ─────────────────────────────────────────────────────
            // ✍️ STEP 5E: LLM WRITES EXPLANATION
            // ─────────────────────────────────────────────────────
            console.log('\n[STEP 5E] ✍️ Generating Human-Readable Explanation');
            groqExplanation = await generateExplanation(
                finalScore,
                finalVerdict,
                extracted.mainClaim,
                comparisonResult.webMatchResult,
                comparisonResult.contradictionDetail,
                detectedCategory
            );
            console.log(`         ✅ Explanation: "${groqExplanation}"`);

            pipelineSucceeded = true;

        } catch (err) {
            // ─────────────────────────────────────────────────────
            // 🔴 FALLBACK: If any step fails
            // ─────────────────────────────────────────────────────
            console.log(`\n[FALLBACK] ⚠️ Pipeline error: ${err.message}`);
            console.log(`           ↳ Falling back to neutral score`);

            finalScore = 50; // no signal at all — return neutral
            finalVerdict = scoreToVerdict(finalScore);
            groqExplanation = 'Live verification failed. Please verify this article manually.';
        }

        // ─────────────────────────────────────────────────────
        // 💾 STEP 6: SAVE TO DATABASE
        // ─────────────────────────────────────────────────────
        console.log('\n[STEP 6] 💾 Saving to Database');
        const record = await Analysis.create({
            userId,
            inputType,
            inputContent,
            totalScore: finalScore,
            verdict: finalVerdict,
            textScore: mlScore, // now stores NLI score
            details: {
                articleText,
                category: detectedCategory,
                mainClaim: extracted.mainClaim || null,
                supportingClaims: extracted.supportingClaims || [],
                keyPerson: extracted.keyPerson || null,
                keyPersonTitle: extracted.keyPersonTitle || null,
                webMatchResult: comparisonResult.webMatchResult || null,
                contradictionFound: comparisonResult.contradictionFound || false,
                contradictionDetail: comparisonResult.contradictionDetail || null,
                nliVerdict,    // NEW: stored for debugging
                groqExplanation,
                pipelineSucceeded,
            }
        });
        console.log(`         ✅ Saved | Record ID: ${record.id}`);

        // ─────────────────────────────────────────────────────
        // 🏁 FINAL SUMMARY
        // ─────────────────────────────────────────────────────
        console.log('\n==================================================');
        console.log('🏁 ANALYSIS COMPLETE — TRUTHGUARD V8.0');
        console.log(`   🏷️  Category     : ${CATEGORIES[detectedCategory].emoji} ${CATEGORIES[detectedCategory].name}`);
        console.log(`   🧠 NLI Verdict  : ${nliVerdict}`);
        console.log(`   🎯 Final Score  : ${finalScore} / 100`);
        console.log(`   ⚖️  Verdict      : ${finalVerdict}`);
        console.log(`   💡 Reason       : ${groqExplanation}`);
        console.log('==================================================\n');

        res.status(201).json({ result: record });

    } catch (err) {
        console.log('\n❌ CRITICAL SERVER ERROR:', err.message);
        console.error(err);
        res.status(500).json({ message: 'Internal server error during analysis.' });
    }
};

// ============================================================
// 📜 GET HISTORY
// ============================================================
const getHistory = async (req, res) => {
    try {
        const records = await Analysis.findAll({
            where: { userId: req.user.id },
            order: [['createdAt', 'DESC']],
        });
        res.json(records);
    } catch (err) {
        console.error('History fetch error:', err.message);
        res.status(500).json({ message: 'Failed to fetch history.' });
    }
};

module.exports = { analyze, getHistory };